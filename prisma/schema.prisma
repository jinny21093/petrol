// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

/// АЗС с platforma35.ru. Уникальна по externalId (id маркера в API).
model Station {
  id         String   @id @default(cuid())
  externalId Int      @unique // id маркера на platforma35.ru (1-9)
  brand      String   @default("Неизвестно")
  address    String   @default("")
  status     String   @default("Нет") // "Да" — АЗС сообщает об остатках
  source     String   @default("platforma35") // источник данных (audit-поле)
  longitude  Float?   // WGS84 (от platforma35)
  latitude   Float?   // WGS84 (от platforma35)
  logoUrl    String?  // URL логотипа бренда
  availabilityFuel Boolean @default(false) // true = есть данные об остатках
  fuelDelivery     Boolean @default(false) // true = ожидается/идёт подвоз
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  snapshots  FuelSnapshot[]
  hidden     Boolean  @default(false)

  @@index([brand])
  @@index([status])
}

/// Снапшот остатков топлива на момент опроса.
model FuelSnapshot {
  id             String   @id @default(cuid())
  stationId      String
  station        Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  rawDetails     String   @default("") // HTML из info (platforma35) или текст (legacy)
  parsedFuels    String   @default("[]") // JSON: {comment, commentDate, fuelDelivery, fuels: [...]}
  sourceCreatedAt   DateTime? // время создания на источнике
  sourceUpdatedAt   DateTime? // время обновления на источнике
  fetchedAt      DateTime @default(now()) // когда мы опросили

  @@index([stationId, sourceUpdatedAt])
  @@index([sourceUpdatedAt])
  @@index([fetchedAt])
}

/// Глобальные настройки системы (key-value).
/// Ключи: lastRefreshAt, sourceStatus, sourceStatusAt
model Setting {
  id    String @id
  value String @default("")
}
