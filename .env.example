# Путь к SQLite базе (абсолютный путь на сервере!)
# Локально можно оставить относительный. На сервере — абсолютный, например:
#   file:/var/www/vologda-azs/db/custom.db
DATABASE_URL="file:./db/custom.db"

# Режим сборки
NODE_ENV="production"

# Порт, на котором слушает Next.js standalone-сервер
PORT=3000
